# Safe local default; production must set this to the deployed platform domain.
PLATFORM_DOMAIN=localhost:3000

# Optional server-only integrations. Set every variable in a group or leave the group empty.
DATABASE_URL=

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

RESEND_API_KEY=
RESEND_FROM=

# Stripe billing (server-only; required in production). Prefer a least-privilege restricted key.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
